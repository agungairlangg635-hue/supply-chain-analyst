      <aliases enabled='yes' />
      <column caption='Delay' datatype='integer' name='[Calculation_1914312659648512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order date (DateOrders)], [shipping date (DateOrders)])&#13;&#10;-&#13;&#10;[Days for shipment (scheduled)]' />
      </column>
      <column caption='Is_Delayed' datatype='integer' name='[Calculation_1914312659755009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1914312659648512] &gt; 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Delay%' datatype='real' name='[Calculation_1914312659877890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1914312659755009]) / COUNT([Order Id])' />
      </column>
      <column caption='Total Profit (positive only)' datatype='real' default-format='c&quot;$&quot;#,##0.00;(&quot;$&quot;#,##0.00)' name='[Calculation_1914312670396419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Order Profit Per Order] &gt; 0 THEN [Order Profit Per Order] END' />
      </column>
      <column caption='Loss' datatype='real' name='[Calculation_1914312670945284]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Order Profit Per Order] &lt; 0 THEN [Order Profit Per Order] END' />
      </column>
      <column caption='Profit at Risk' datatype='real' name='[Calculation_1914312672395270]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1914312659648512] &gt; 0 THEN [Order Profit Per Order] END' />
      </column>
      <column caption='loss delay' datatype='real' name='[Calculation_1914312675332103]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1914312659648512] &gt; 0 AND [Order Profit Per Order] &lt; 0 THEN [Order Profit Per Order] END' />
      </column>
